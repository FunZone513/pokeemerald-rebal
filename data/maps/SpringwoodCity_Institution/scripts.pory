mapscripts SpringwoodCity_Institution_MapScripts {
    MAP_SCRIPT_ON_TRANSITION: SpringwoodCity_Institution_CheckState
}

script SpringwoodCity_Institution_CheckState {
    if (var(VAR_DYECRESS_MYSTERY_STATE) >= 4) {
        setflag(FLAG_TEMP_A)
    }

    if (flag(FLAG_CLEARED_ROUTE5)) {
        setflag(FLAG_TEMP_10)
        setflag(FLAG_TEMP_11)
        setflag(FLAG_TEMP_12)
    }
}

script SpringwoodCity_Institution_Receptionist {
    lockall
    msgbox("Welcome to the Libra Institute!\nDo you happen to have an appointment?")
    if (var(VAR_DYECRESS_MYSTERY_STATE) == 2) {
        msgbox(SpringwoodCity_Institution_Receptionist_Dyecress_Mystery1, MSGBOX_NPC)
        setvar(VAR_DYECRESS_MYSTERY_STATE, 3)
    } elif (var(VAR_DYECRESS_MYSTERY_STATE) == 3) {
        msgbox(format("If you're looking for the researchers to help out Simon, you'll find them up the stairs to the left."), MSGBOX_NPC)
    }
    releaseall
}

text SpringwoodCity_Institution_Receptionist_Dyecress_Mystery1 {
    "...\p"
    "You have a message from a wordy Old Man\nin Dyecress Town?\p"
    "I see!\p"
    "Our insitute has had quite an interest\nin Dyecress for quite a while now,\lbut Simon was reluctant to let us\linvestigate the town.\p"
    "If he's sent you here as a request for\nhelp, then I can only imagine how\lstumped he must be on his current task.\p"
    "Please make your way up the stairs to\nthe left, our in-house researches would\lbe honoured to lend a hand."
}

